# .env.example
# Copy to .env and fill in values before running the OpenAI demo or notebooks.
# Never commit .env to version control.

# Required for the LangChain + OpenAI demo (demo/demo_block.py with live agent).
# Not required for standalone middleware use (no API calls are made by default).
OPENAI_API_KEY=your-openai-api-key-here

# Optional: override the default detection threshold (0.0 – 1.0).
# PI_THRESHOLD=0.50

# Optional: override the default high-risk threshold.
# PI_HIGH_RISK_THRESHOLD=0.85

# Optional: detection mode — "rules" | "hybrid" | "full"
# PI_MODE=hybrid

# Optional: policy strategy — "allow" | "annotate" | "redact" | "block"
# PI_STRATEGY=block
